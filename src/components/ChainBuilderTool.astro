---
import Layout from "~/layouts/Layout.astro";
import PrivacyBadge from "~/components/PrivacyBadge.astro";
import Modal from "~/components/Modal.astro";
import ToolNav from "~/components/ToolNav.astro";
import { getMessages, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const m = getMessages(locale);
const desc =
  locale === "it"
    ? "Incolla un bundle PEM (in qualsiasi ordine). Ricostruisce la catena leaf → root, verifica le firme link-by-link, segnala se manca un intermediate. Niente upload."
    : locale === "de"
      ? "PEM-Bundle (in beliebiger Reihenfolge) einfügen. Wir rekonstruieren die Kette Leaf → Root, prüfen Signaturen pro Link und melden fehlende Intermediates. Kein Upload."
      : locale === "fr"
        ? "Collez un paquet PEM (dans n'importe quel ordre). Nous reconstruisons la chaîne feuille → racine, vérifions chaque signature et signalons les intermédiaires manquants. Aucun upload."
        : "Paste a bundle of PEM blocks in any order. We reconstruct the leaf → root chain, verify each signature, and flag missing intermediates. Nothing uploaded.";
---

<Layout
  title={m.chainBuilderTitle}
  description={desc}
  keywords={[
    "certificate chain validator",
    "ssl chain builder",
    "fullchain pem",
    "intermediate fetcher",
    "validate ssl chain",
  ]}
  compact
>
  <div
    class="flex-1 flex flex-col items-stretch justify-start md:justify-center px-4 py-6 md:py-10"
  >
    <div class="w-full max-w-3xl mx-auto">
      <ToolNav locale={locale} currentSlug="chain-builder" />
      <header class="mb-5">
        <h1
          class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50"
        >
          {m.chainBuilderTitle}
        </h1>
        <p class="mt-1.5 text-zinc-600 dark:text-zinc-400 leading-relaxed">
          {m.chainBuilderTagline}
        </p>
        <div class="mt-3"><PrivacyBadge locale={locale} variant="inline" /></div>
      </header>

      <div
        class:list={[
          "rounded-2xl border shadow-sm overflow-hidden",
          "bg-white border-zinc-200",
          "dark:bg-zinc-900 dark:border-zinc-800",
        ]}
      >
        <div
          class:list={[
            "flex items-center justify-between gap-3 border-b px-4 py-2.5",
            "bg-zinc-50/60 border-zinc-100",
            "dark:bg-zinc-900/80 dark:border-zinc-800",
          ]}
        >
          <div class="text-xs font-medium text-zinc-500 dark:text-zinc-400">
            Paste leaf, intermediates and (optionally) root — any order
          </div>
          <button
            type="button"
            data-action="clear"
            class="text-xs font-medium text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
            >{m.clear}</button
          >
        </div>
        <textarea
          id="chain-input"
          rows="14"
          spellcheck="false"
          autocomplete="off"
          autocapitalize="off"
          autocorrect="off"
          placeholder="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
          class:list={[
            "mono w-full resize-y border-0 px-4 py-3 focus:outline-none focus:ring-0",
            "bg-white text-zinc-900 placeholder:text-zinc-400",
            "dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder:text-zinc-600",
          ]}></textarea>
      </div>

      <div class="mt-4 flex items-center gap-3 flex-wrap">
        <button
          type="button"
          data-action="build"
          class:list={[
            "inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
            "bg-zinc-900 text-white hover:bg-zinc-800",
            "dark:bg-brand-500 dark:text-zinc-50 dark:hover:bg-brand-400",
          ]}>Build & validate chain</button
        >
        <p id="status" role="status" aria-live="polite" class="text-sm text-zinc-500 dark:text-zinc-400"></p>
      </div>

      <div
        id="error"
        role="alert"
        class:list={[
          "mt-5 hidden rounded-lg border px-4 py-3 text-sm",
          "bg-red-50 border-red-200 text-red-900",
          "dark:bg-red-950/40 dark:border-red-900/60 dark:text-red-200",
        ]}
      >
      </div>

    </div>
  </div>

  <Modal id="result-modal" locale={locale}>
    <span slot="title">{m.chainBuilderTitle}</span>
    <span slot="subtitle" id="result-modal-subtitle"></span>
    <div id="result-body"></div>
  </Modal>
</Layout>

<script>
  import { buildChain, type ChainNode } from "~/lib/chain";
  import { escapeHtml, formatDate } from "~/lib/util";

  const $input = document.getElementById("chain-input") as HTMLTextAreaElement;
  const $status = document.getElementById("status") as HTMLElement;
  const $error = document.getElementById("error") as HTMLElement;
  const $modal = document.getElementById("result-modal") as HTMLDialogElement;
  const $subtitle = document.getElementById("result-modal-subtitle") as HTMLElement;
  const $body = document.getElementById("result-body") as HTMLElement;
  const $btn = document.querySelector('[data-action="build"]') as HTMLButtonElement;

  let busy = false;
  function setBusy(v: boolean) {
    busy = v;
    $btn.disabled = v;
    $btn.textContent = v ? "Working…" : "Build & validate chain";
  }
  function showError(msg: string) {
    $error.textContent = msg;
    $error.classList.remove("hidden");
    $status.textContent = "";
  }

  function nodeCard(n: ChainNode, role: string): string {
    const expiryClass = n.expired
      ? "text-red-700 dark:text-red-300"
      : "text-zinc-700 dark:text-zinc-300";
    return `<div class="rounded-lg border border-zinc-200 bg-white p-4 dark:bg-zinc-900/40 dark:border-zinc-800">
      <div class="flex items-center justify-between flex-wrap gap-2">
        <div class="min-w-0">
          <div class="text-[10px] font-medium uppercase tracking-wider text-brand-700 dark:text-brand-400">${escapeHtml(role)}</div>
          <h4 class="font-semibold text-zinc-900 dark:text-zinc-50 truncate">${escapeHtml(n.commonName ?? n.subject)}</h4>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 truncate">issued by ${escapeHtml(n.issuerCommonName ?? n.issuer)}</p>
        </div>
        ${n.selfSigned ? '<span class="text-[10px] uppercase tracking-wider rounded-md bg-zinc-100 text-zinc-700 px-1.5 py-0.5 dark:bg-zinc-800 dark:text-zinc-300">self-signed</span>' : ""}
      </div>
      <div class="mt-3 text-xs ${expiryClass}">
        valid ${escapeHtml(formatDate(n.notBefore))} → ${escapeHtml(formatDate(n.notAfter))}${n.expired ? " (EXPIRED)" : n.notYetValid ? " (NOT YET VALID)" : ""}
      </div>
    </div>`;
  }

  async function run() {
    if (busy) return;
    $error.classList.add("hidden");
    if (!$input.value.trim()) {
      $status.textContent = "Paste one or more PEM blocks.";
      return;
    }
    setBusy(true);
    $status.textContent = "Working…";
    try {
      const r = await buildChain($input.value);
      if (!r.ok) {
        showError(r.error);
        return;
      }
      const res = r.result;
      const roles = res.ordered.map((_idx, i) => {
        if (i === 0) return "leaf";
        if (i === res.ordered.length - 1 && res.rootSelfSigned) return "root";
        return `intermediate #${i}`;
      });
      const orderedNodes = res.ordered
        .map((idx, i) => nodeCard(res.nodes[idx]!, roles[i]!))
        .join("");
      const linksHtml = res.links
        .map((l) => {
          const ok = l.signatureValid && l.validityOk;
          const badge = ok
            ? '<span class="text-emerald-700 dark:text-emerald-400">✓ link OK</span>'
            : '<span class="text-red-700 dark:text-red-300">✗ link failed</span>';
          return `<li class="flex items-center justify-between gap-3 py-1 text-sm border-b last:border-0 border-zinc-100 dark:border-zinc-800">
            <span class="text-zinc-700 dark:text-zinc-300">cert #${l.childIndex + 1} → #${l.parentIndex + 1}</span>
            ${badge}
            ${l.signatureError ? `<span class="text-xs text-red-700 dark:text-red-300">${escapeHtml(l.signatureError)}</span>` : ""}
          </li>`;
        })
        .join("");
      const missingHtml = res.missingIssuer
        ? `<div class="rounded-md border border-amber-200 bg-amber-50/60 px-3 py-2 text-xs text-amber-900 leading-relaxed dark:bg-amber-950/30 dark:border-amber-900/60 dark:text-amber-200">
            Missing parent for cert #${res.missingIssuer.forIndex + 1} — expected issuer
            <span class="font-medium">${escapeHtml(res.missingIssuer.issuerCN ?? "")}</span>.
            ${res.missingIssuer.aiaUrl ? `Fetch from AIA: <a class="underline mono" href="${escapeHtml(res.missingIssuer.aiaUrl)}" target="_blank" rel="noopener">${escapeHtml(res.missingIssuer.aiaUrl)}</a>` : ""}
          </div>`
        : "";
      const overall = res.allValid
        ? '<span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 text-emerald-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-emerald-200 dark:bg-emerald-950/40 dark:text-emerald-200 dark:ring-emerald-900/60">✓ chain valid</span>'
        : '<span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 text-amber-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-amber-200 dark:bg-amber-950/40 dark:text-amber-200 dark:ring-amber-900/60">⚠ issues found</span>';
      $subtitle.textContent = `${res.ordered.length} certificate${res.ordered.length === 1 ? "" : "s"} ordered.`;
      $body.innerHTML = `<article class="space-y-4">
        <header class="flex items-center justify-between flex-wrap gap-3">
          <div class="text-sm text-zinc-600 dark:text-zinc-400">Chain order: leaf → root</div>
          ${overall}
        </header>
        ${missingHtml}
        <div class="grid gap-3">${orderedNodes}</div>
        <div class="rounded-lg border border-zinc-200 bg-white p-4 dark:bg-zinc-900/40 dark:border-zinc-800">
          <div class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-2">Per-link verification</div>
          <ul>${linksHtml || `<li class="text-sm text-zinc-500 italic">No links to verify (single cert).</li>`}</ul>
        </div>
      </article>`;
      $status.textContent = $subtitle.textContent;
      if (!$modal.open) $modal.showModal();
    } finally {
      setBusy(false);
    }
  }

  $btn.addEventListener("click", () => void run());
  document.querySelector('[data-action="clear"]')?.addEventListener("click", () => {
    $input.value = "";
    $error.classList.add("hidden");
    $status.textContent = "";
    $input.focus();
  });
  $input.addEventListener("paste", () => {
    setTimeout(() => {
      const v = $input.value;
      const blocks = (v.match(/-----BEGIN CERTIFICATE-----/g) ?? []).length;
      if (blocks >= 2) void run();
    }, 0);
  });
</script>
