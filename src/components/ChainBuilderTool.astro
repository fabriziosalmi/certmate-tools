---
import Layout from "~/layouts/Layout.astro";
import PrivacyBadge from "~/components/PrivacyBadge.astro";
import Modal from "~/components/Modal.astro";
import ToolNav from "~/components/ToolNav.astro";
import { getMessages, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const m = getMessages(locale);
const desc =
  locale === "it"
    ? "Incolla un bundle PEM (in qualsiasi ordine). Ricostruisce la catena leaf → root, verifica le firme link-by-link, segnala se manca un intermediate. Niente upload."
    : "Paste a bundle of PEM blocks in any order. We reconstruct the leaf → root chain, verify each signature, and flag missing intermediates. Nothing uploaded.";
---

<Layout
  title={m.chainBuilderTitle}
  description={desc}
  keywords={[
    "certificate chain validator",
    "ssl chain builder",
    "fullchain pem",
    "intermediate fetcher",
    "validate ssl chain",
  ]}
  compact
>
  <div
    class="flex-1 flex flex-col items-stretch justify-start md:justify-center px-4 py-6 md:py-10"
  >
    <div class="w-full max-w-3xl mx-auto">
      <ToolNav locale={locale} currentSlug="chain-builder" />
      <header class="mb-5">
        <h1
          class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50"
        >
          {m.chainBuilderTitle}
        </h1>
        <p class="mt-1.5 text-zinc-600 dark:text-zinc-400 leading-relaxed">
          {m.chainBuilderTagline}
        </p>
        <div class="mt-3"><PrivacyBadge locale={locale} variant="inline" /></div>
      </header>

      <div
        class:list={[
          "rounded-2xl border shadow-sm overflow-hidden",
          "bg-white border-zinc-200",
          "dark:bg-zinc-900 dark:border-zinc-800",
        ]}
      >
        <div
          class:list={[
            "flex flex-wrap items-center justify-between gap-2 border-b px-4 py-2.5",
            "bg-zinc-50/60 border-zinc-100",
            "dark:bg-zinc-900/80 dark:border-zinc-800",
          ]}
        >
          <div class="text-xs font-medium text-zinc-500 dark:text-zinc-400">
            {m.chainBuilderHint}
          </div>
          <button
            type="button"
            data-action="clear"
            class="text-xs font-medium text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
            >{m.clear}</button
          >
        </div>
        <textarea
          id="chain-input"
          rows="14"
          spellcheck="false"
          autocomplete="off"
          autocapitalize="off"
          autocorrect="off"
          placeholder="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
          class:list={[
            "mono w-full resize-y border-0 px-4 py-3 text-base sm:text-sm leading-relaxed min-h-56 focus:outline-none focus:ring-0",
            "bg-white text-zinc-900 placeholder:text-zinc-400",
            "dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder:text-zinc-600",
          ]}></textarea>
      </div>

      <div class="mt-4 flex items-center gap-3 flex-wrap">
        <button
          type="button"
          data-action="build"
          class:list={[
            "inline-flex w-full sm:w-auto justify-center items-center gap-2 rounded-md px-5 py-3 text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
            "bg-zinc-900 text-white hover:bg-zinc-800",
            "dark:bg-brand-500 dark:text-zinc-50 dark:hover:bg-brand-400",
          ]}>{m.chainBuilderRunButton}</button
        >
        <p id="status" role="status" aria-live="polite" class="w-full sm:w-auto text-xs sm:text-sm leading-relaxed text-zinc-500 dark:text-zinc-400"></p>
      </div>

      <div
        id="error"
        role="alert"
        class:list={[
          "mt-5 hidden rounded-lg border px-4 py-3 text-sm",
          "bg-red-50 border-red-200 text-red-900",
          "dark:bg-red-950/40 dark:border-red-900/60 dark:text-red-200",
        ]}
      >
      </div>

    </div>
  </div>

  <Modal id="result-modal" locale={locale}>
    <span slot="title">{m.chainBuilderTitle}</span>
    <span slot="subtitle" id="result-modal-subtitle"></span>
    <div id="result-body"></div>
  </Modal>
</Layout>

<script>
  import { buildChain, chainToBundle, type ChainNode, type ChainResult } from "~/lib/chain";
  import { escapeHtml, formatDate, MAX_INPUT_BYTES } from "~/lib/util";
  import { detectLocale, getMessages } from "~/i18n";

  const locale = detectLocale(location.pathname);
  const m = getMessages(locale);

  const $input = document.getElementById("chain-input") as HTMLTextAreaElement;
  const $status = document.getElementById("status") as HTMLElement;
  const $error = document.getElementById("error") as HTMLElement;
  const $modal = document.getElementById("result-modal") as HTMLDialogElement;
  const $subtitle = document.getElementById("result-modal-subtitle") as HTMLElement;
  const $body = document.getElementById("result-body") as HTMLElement;
  const $btn = document.querySelector('[data-action="build"]') as HTMLButtonElement;

  let busy = false;
  let lastResult: ChainResult | null = null;
  function setBusy(v: boolean) {
    busy = v;
    $btn.disabled = v;
    $btn.textContent = v ? m.decodingButton : m.chainBuilderRunButton;
  }
  function showError(msg: string) {
    $error.textContent = msg;
    $error.classList.remove("hidden");
    $status.textContent = "";
  }

  function nodeCard(n: ChainNode, role: string): string {
    const expiryClass = n.expired
      ? "text-red-700 dark:text-red-300"
      : "text-zinc-700 dark:text-zinc-300";
    const expiryStateLabel = n.expired
      ? ` (${escapeHtml(m.commonExpired)})`
      : n.notYetValid
        ? ` (${escapeHtml(m.commonNotYetValid)})`
        : "";
    const selfSignedBadge = n.selfSigned
      ? `<span class="text-[10px] uppercase tracking-wider rounded-md bg-zinc-100 text-zinc-700 px-1.5 py-0.5 dark:bg-zinc-800 dark:text-zinc-300">${escapeHtml(m.commonSelfSigned)}</span>`
      : "";
    return `<div class="rounded-lg border border-zinc-200 bg-white p-4 dark:bg-zinc-900/40 dark:border-zinc-800">
      <div class="flex items-center justify-between flex-wrap gap-2">
        <div class="min-w-0">
          <div class="text-[10px] font-medium uppercase tracking-wider text-brand-700 dark:text-brand-400">${escapeHtml(role)}</div>
          <h4 class="font-semibold text-zinc-900 dark:text-zinc-50 truncate">${escapeHtml(n.commonName ?? n.subject)}</h4>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 truncate">${escapeHtml(m.commonIssuedBy)} ${escapeHtml(n.issuerCommonName ?? n.issuer)}</p>
        </div>
        ${selfSignedBadge}
      </div>
      <div class="mt-3 text-xs ${expiryClass}">
        ${escapeHtml(formatDate(n.notBefore))} → ${escapeHtml(formatDate(n.notAfter))}${expiryStateLabel}
      </div>
    </div>`;
  }

  async function run() {
    if (busy) return;
    $error.classList.add("hidden");
    if (!$input.value.trim()) {
      $status.textContent = m.chainBuilderStatusEmpty;
      return;
    }
    if ($input.value.length > MAX_INPUT_BYTES) {
      showError(m.inputTooLarge);
      return;
    }
    setBusy(true);
    $status.textContent = m.decodingButton;
    try {
      const r = await buildChain($input.value);
      if (!r.ok) {
        showError(r.error);
        return;
      }
      const res = r.result;
      const roles = res.ordered.map((_idx, i) => {
        if (i === 0) return m.chainRoleLeaf;
        if (i === res.ordered.length - 1 && res.rootSelfSigned) return m.chainRoleRoot;
        return `${m.chainRoleIntermediate} #${i}`;
      });
      const orderedNodes = res.ordered
        .map((idx, i) => nodeCard(res.nodes[idx]!, roles[i]!))
        .join("");
      const linksHtml = res.links
        .map((l) => {
          const ok = l.signatureValid && l.validityOk;
          const badge = ok
            ? `<span class="text-emerald-700 dark:text-emerald-400">✓ ${escapeHtml(m.chainLinkOk)}</span>`
            : `<span class="text-red-700 dark:text-red-300">✗ ${escapeHtml(m.chainLinkFailed)}</span>`;
          return `<li class="flex items-center justify-between gap-3 py-1 text-sm border-b last:border-0 border-zinc-100 dark:border-zinc-800">
            <span class="text-zinc-700 dark:text-zinc-300">cert #${l.childIndex + 1} → #${l.parentIndex + 1}</span>
            ${badge}
            ${l.signatureError ? `<span class="text-xs text-red-700 dark:text-red-300">${escapeHtml(l.signatureError)}</span>` : ""}
          </li>`;
        })
        .join("");
      const missingHtml = res.missingIssuer
        ? `<div class="rounded-md border border-amber-200 bg-amber-50/60 px-3 py-2 text-xs text-amber-900 leading-relaxed dark:bg-amber-950/30 dark:border-amber-900/60 dark:text-amber-200">
            ${escapeHtml(m.chainMissingParentPrefix)} #${res.missingIssuer.forIndex + 1} — ${escapeHtml(m.chainExpectedIssuer)}
            <span class="font-medium">${escapeHtml(res.missingIssuer.issuerCN ?? "")}</span>.
            ${res.missingIssuer.aiaUrl ? `${escapeHtml(m.chainFetchAia)} <a class="underline mono" href="${escapeHtml(res.missingIssuer.aiaUrl)}" target="_blank" rel="noopener">${escapeHtml(res.missingIssuer.aiaUrl)}</a>` : ""}
          </div>`
        : "";
      const overall = res.allValid
        ? `<span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 text-emerald-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-emerald-200 dark:bg-emerald-950/40 dark:text-emerald-200 dark:ring-emerald-900/60">✓ ${escapeHtml(m.chainOverallValid)}</span>`
        : `<span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 text-amber-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-amber-200 dark:bg-amber-950/40 dark:text-amber-200 dark:ring-amber-900/60">⚠ ${escapeHtml(m.chainOverallIssues)}</span>`;
      $subtitle.textContent = m.chainSubtitle(res.ordered.length);
      lastResult = res;
      $body.innerHTML = `<article class="space-y-4">
        <header class="flex items-center justify-between flex-wrap gap-3">
          <div class="text-sm text-zinc-600 dark:text-zinc-400">${escapeHtml(m.chainOrder)}</div>
          <div class="flex items-center gap-3">
            ${overall}
            <button type="button" data-action="download-bundle" class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-medium ring-1 transition-colors bg-white text-zinc-900 ring-zinc-300 hover:bg-zinc-50 dark:bg-zinc-900 dark:text-zinc-100 dark:ring-zinc-700 dark:hover:bg-zinc-800">
              <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 fill-current" aria-hidden="true"><path d="M10 3a1 1 0 011 1v7.586l2.293-2.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 11.586V4a1 1 0 011-1zM4 16a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1z"></path></svg>
              ${escapeHtml(m.chainBuilderDownloadBundle)}
            </button>
          </div>
        </header>
        ${missingHtml}
        <div class="grid gap-3">${orderedNodes}</div>
        <div class="rounded-lg border border-zinc-200 bg-white p-4 dark:bg-zinc-900/40 dark:border-zinc-800">
          <div class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-2">${escapeHtml(m.chainPerLink)}</div>
          <ul>${linksHtml || `<li class="text-sm text-zinc-500 italic">${escapeHtml(m.chainNoLinks)}</li>`}</ul>
        </div>
      </article>`;
      $status.textContent = $subtitle.textContent;
      if (!$modal.open) $modal.showModal();
    } finally {
      setBusy(false);
    }
  }

  $btn.addEventListener("click", () => void run());
  document.querySelector('[data-action="clear"]')?.addEventListener("click", () => {
    $input.value = "";
    $error.classList.add("hidden");
    $status.textContent = "";
    lastResult = null;
    $input.focus();
  });

  // Event delegation: the download button is injected into the modal body on
  // each run, so we bind to the modal container once.
  $body.addEventListener("click", (e) => {
    const t = (e.target as HTMLElement | null)?.closest('[data-action="download-bundle"]');
    if (!t || !lastResult) return;
    const bundle = chainToBundle(lastResult.nodes, lastResult.ordered);
    const blob = new Blob([bundle], { type: "application/x-pem-file" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "fullchain.pem";
    a.click();
    URL.revokeObjectURL(url);
  });
  $input.addEventListener("paste", () => {
    setTimeout(() => {
      const v = $input.value;
      const blocks = (v.match(/-----BEGIN CERTIFICATE-----/g) ?? []).length;
      if (blocks >= 2) void run();
    }, 0);
  });
</script>
