---
import Layout from "~/layouts/Layout.astro";
import PrivacyBadge from "~/components/PrivacyBadge.astro";
import Modal from "~/components/Modal.astro";
import ToolNav from "~/components/ToolNav.astro";
import { getMessages, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const m = getMessages(locale);
const desc =
  locale === "it"
    ? "Decodifica online qualsiasi CSR PKCS#10 nel browser. Vedi CN, SAN, parametri chiave, attributi richiesti — niente upload."
    : "Decode any PKCS#10 Certificate Signing Request in your browser. See CN, SAN, key parameters and challenge attributes — no upload.";
---

<Layout
  title={m.csrDecoderTitle}
  description={desc}
  keywords={[
    "csr decoder",
    "pkcs10 decoder",
    "csr parser",
    "decoder csr",
    "certificate signing request",
  ]}
  compact
>
  <div
    class="flex-1 flex flex-col items-stretch justify-start md:justify-center px-4 py-6 md:py-10"
  >
    <div class="w-full max-w-3xl mx-auto">
      <ToolNav locale={locale} currentSlug="csr-decoder" />
      <header class="mb-5">
        <h1
          class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50"
        >
          {m.csrDecoderTitle}
        </h1>
        <p class="mt-1.5 text-zinc-600 dark:text-zinc-400 leading-relaxed">
          {m.csrDecoderTagline}
        </p>
        <div class="mt-3"><PrivacyBadge locale={locale} variant="inline" /></div>
      </header>

      <div
        id="card"
        class:list={[
          "rounded-2xl border shadow-sm overflow-hidden",
          "bg-white border-zinc-200",
          "dark:bg-zinc-900 dark:border-zinc-800",
        ]}
      >
        <div
          class:list={[
            "flex flex-wrap items-center justify-between gap-2 border-b px-4 py-2.5",
            "bg-zinc-50/60 border-zinc-100",
            "dark:bg-zinc-900/80 dark:border-zinc-800",
          ]}
        >
          <div class="text-xs font-medium text-zinc-500 dark:text-zinc-400">
            {m.pasteHint}
          </div>
          <div class="flex items-center gap-2 text-xs">
            <button
              type="button"
              data-action="sample"
              class="font-medium text-brand-700 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300"
              >{m.tryWithSample}</button
            >
            <span class="text-zinc-300 dark:text-zinc-700">·</span>
            <button
              type="button"
              data-action="clear"
              class="font-medium text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
              >{m.clear}</button
            >
          </div>
        </div>
        <textarea
          id="csr-input"
          rows="10"
          spellcheck="false"
          autocomplete="off"
          autocapitalize="off"
          autocorrect="off"
          maxlength="2097152"
          placeholder={m.csrDecoderPlaceholder}
          class:list={[
            "mono w-full resize-y border-0 px-4 py-4 text-base sm:text-sm leading-relaxed min-h-48 focus:outline-none focus:ring-0",
            "bg-white text-zinc-900 placeholder:text-zinc-400",
            "dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder:text-zinc-600",
          ]}></textarea>
      </div>

      <div class="mt-4 flex items-center gap-3 flex-wrap">
        <button
          type="button"
          data-action="decode"
          class:list={[
            "inline-flex w-full sm:w-auto justify-center items-center gap-2 rounded-md px-5 py-3 text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
            "bg-zinc-900 text-white hover:bg-zinc-800",
            "dark:bg-brand-500 dark:text-zinc-50 dark:hover:bg-brand-400",
          ]}>{m.decodeButton}</button
        >
        <p id="status" role="status" aria-live="polite" class="w-full sm:w-auto text-xs sm:text-sm leading-relaxed text-zinc-500 dark:text-zinc-400"></p>
      </div>

      <div
        id="error"
        role="alert"
        class:list={[
          "mt-5 hidden rounded-lg border px-4 py-3 text-sm",
          "bg-red-50 border-red-200 text-red-900",
          "dark:bg-red-950/40 dark:border-red-900/60 dark:text-red-200",
        ]}
      >
      </div>

    </div>
  </div>

  <Modal id="result-modal" locale={locale}>
    <span slot="title">{m.resultsHeader}</span>
    <span slot="subtitle" id="result-modal-subtitle"></span>
    <div id="result-body"></div>
  </Modal>
</Layout>

<script>
  import {
    decodeCSRInput,
    SAMPLE_CSR,
    type DecodedCSR,
  } from "~/lib/csr-decoder";
  import { MAX_INPUT_BYTES } from "~/lib/util";
  import { el, frag, mount, type ChildValue } from "~/lib/dom";
  import { detectLocale, getMessages } from "~/i18n";

  const locale = detectLocale(location.pathname);
  const m = getMessages(locale);

  const $input = document.getElementById("csr-input") as HTMLTextAreaElement;
  const $status = document.getElementById("status") as HTMLElement;
  const $error = document.getElementById("error") as HTMLElement;
  const $modal = document.getElementById("result-modal") as HTMLDialogElement;
  const $subtitle = document.getElementById("result-modal-subtitle") as HTMLElement;
  const $body = document.getElementById("result-body") as HTMLElement;
  const $btn = document.querySelector(
    '[data-action="decode"]'
  ) as HTMLButtonElement;

  let busy = false;
  function setBusy(v: boolean) {
    busy = v;
    $btn.disabled = v;
    $btn.textContent = v ? m.decodingButton : m.decodeButton;
  }
  function showError(msg: string) {
    $error.textContent = msg;
    $error.classList.remove("hidden");
    $status.textContent = "";
  }

  function chips(items: string[]): HTMLElement {
    if (items.length === 0)
      return el(
        "p",
        { class: "text-sm text-zinc-500 italic dark:text-zinc-500" },
        "none"
      );
    return el(
      "div",
      { class: "flex flex-wrap gap-1.5" },
      items.map((i) =>
        el(
          "span",
          {
            class:
              "inline-flex rounded-md bg-zinc-100 text-zinc-800 px-2 py-1 text-xs font-medium mono dark:bg-zinc-800 dark:text-zinc-200",
          },
          i
        )
      )
    );
  }

  function copyableValue(value: string, label: string): HTMLElement {
    const code = el(
      "code",
      { class: "mono text-xs break-all flex-1" },
      value
    );
    const btn = el(
      "button",
      {
        type: "button",
        class:
          "shrink-0 text-xs text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100",
        "aria-label": `Copy ${label}`,
      },
      m.copy
    );
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(code.textContent ?? "");
        const prev = btn.textContent;
        btn.textContent = m.copied;
        setTimeout(() => (btn.textContent = prev), 1500);
      } catch {}
    });
    return el("div", { class: "flex items-start gap-2" }, code, btn);
  }

  function field(label: string, value: ChildValue, mono = false): HTMLElement {
    return el(
      "div",
      null,
      el(
        "dt",
        {
          class:
            "text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400",
        },
        label
      ),
      el(
        "dd",
        {
          class: `${mono ? "mono " : ""}mt-1 text-sm text-zinc-900 break-all dark:text-zinc-100`,
        },
        value
      )
    );
  }

  function section(title: string, body: ChildValue): HTMLElement {
    return el(
      "div",
      {
        class:
          "rounded-lg border border-zinc-200 bg-white p-5 dark:bg-zinc-900/40 dark:border-zinc-800",
      },
      el(
        "h3",
        {
          class:
            "text-sm font-semibold uppercase tracking-wider text-brand-700 dark:text-brand-400 mb-3",
        },
        title
      ),
      body
    );
  }

  function sigBadge(csr: DecodedCSR): HTMLElement {
    if (csr.signatureValid === true) {
      return el(
        "span",
        {
          class:
            "inline-flex items-center gap-1.5 rounded-full bg-emerald-100 text-emerald-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-emerald-200 dark:bg-emerald-950/40 dark:text-emerald-200 dark:ring-emerald-900/60",
        },
        el("span", { class: "h-1.5 w-1.5 rounded-full bg-emerald-500" }),
        m.validSignature
      );
    }
    if (csr.signatureValid === false) {
      return el(
        "span",
        {
          class:
            "inline-flex items-center gap-1.5 rounded-full bg-red-100 text-red-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-red-200 dark:bg-red-950/50 dark:text-red-200 dark:ring-red-900/60",
        },
        el("span", { class: "h-1.5 w-1.5 rounded-full bg-red-500" }),
        m.invalidSignature
      );
    }
    const detail = csr.signatureCheckError
      ? ` — ${csr.signatureCheckError}`
      : "";
    return el(
      "span",
      {
        title: csr.signatureCheckError ?? null,
        class:
          "inline-flex items-center gap-1.5 rounded-full bg-amber-100 text-amber-900 px-2.5 py-1 text-xs font-semibold ring-1 ring-amber-200 dark:bg-amber-950/40 dark:text-amber-200 dark:ring-amber-900/60",
      },
      el("span", { class: "h-1.5 w-1.5 rounded-full bg-amber-500" }),
      `${m.signatureCheckErrored}${detail}`
    );
  }

  function renderCSR(csr: DecodedCSR): HTMLElement {
    const cn = csr.subjectDN["CN"]?.[0] ?? csr.subject ?? "CSR";

    const subjBody = el(
      "dl",
      { class: "grid grid-cols-[7rem_1fr] gap-x-4 gap-y-1.5 text-sm" },
      Object.entries(csr.subjectDN).flatMap(([k, vs]) => {
        const ddChildren: ChildValue[] = [];
        vs.forEach((v, i) => {
          if (i > 0) ddChildren.push(el("br"));
          ddChildren.push(v);
        });
        return [
          el(
            "dt",
            { class: "text-zinc-500 font-medium dark:text-zinc-400" },
            k
          ),
          el(
            "dd",
            { class: "text-zinc-900 mono break-all dark:text-zinc-100" },
            ddChildren
          ),
        ];
      })
    );

    const keyBody = el(
      "dl",
      { class: "grid sm:grid-cols-2 gap-4" },
      field(m.commonAlgorithm, csr.publicKey.algorithm),
      csr.publicKey.keySize
        ? field(m.commonKeySize, `${csr.publicKey.keySize} bits`)
        : null,
      csr.publicKey.namedCurve
        ? field(m.commonCurve, csr.publicKey.namedCurve)
        : null,
      field(m.commonSignature, csr.signatureAlgorithm)
    );

    const sanBody =
      csr.san.length > 0
        ? el(
            "div",
            { class: "flex flex-wrap gap-1.5" },
            csr.san.map((e) =>
              el(
                "span",
                {
                  class:
                    "inline-flex items-center rounded-md bg-zinc-100 text-zinc-800 pl-1.5 pr-2 py-0.5 text-xs font-medium dark:bg-zinc-800 dark:text-zinc-200",
                },
                el(
                  "span",
                  {
                    class:
                      "mr-1.5 rounded-sm bg-brand-100 text-brand-800 px-1 text-[10px] uppercase tracking-wider dark:bg-brand-900/40 dark:text-brand-200",
                  },
                  e.type
                ),
                el("span", { class: "mono" }, e.value)
              )
            )
          )
        : el(
            "p",
            { class: "text-sm text-zinc-500 italic dark:text-zinc-500" },
            m.csrNoSAN
          );

    const usageBody = el(
      "div",
      { class: "space-y-3" },
      el(
        "div",
        null,
        el(
          "div",
          {
            class:
              "text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-1",
          },
          m.commonKeyUsage
        ),
        chips(csr.keyUsage)
      ),
      el(
        "div",
        null,
        el(
          "div",
          {
            class:
              "text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-1",
          },
          m.commonEKU
        ),
        chips(csr.extendedKeyUsage)
      ),
      el(
        "div",
        { class: "text-sm text-zinc-700 dark:text-zinc-300" },
        `${m.commonCaRequested}: `,
        el(
          "span",
          { class: "font-semibold" },
          csr.isCA ? m.commonYes : m.commonNo
        ),
        csr.pathLenConstraint != null ? `, pathlen ${csr.pathLenConstraint}` : ""
      )
    );

    const idBody = el(
      "dl",
      { class: "space-y-3" },
      field(
        m.commonSpkiHash,
        copyableValue(csr.spkiFingerprintSha256, "spki"),
        true
      ),
      csr.challengePassword
        ? field(
            m.csrChallengePassword,
            el("code", { class: "mono" }, csr.challengePassword),
            true
          )
        : null,
      csr.unhandledOidAttrs.length
        ? field(m.csrOtherAttributes, chips(csr.unhandledOidAttrs))
        : null
    );

    return el(
      "article",
      { class: "space-y-4" },
      el(
        "header",
        { class: "flex items-start justify-between gap-3 flex-wrap" },
        el(
          "div",
          null,
          el(
            "h2",
            {
              class:
                "text-lg font-bold tracking-tight text-zinc-900 dark:text-zinc-50",
            },
            cn
          ),
          el(
            "p",
            { class: "mt-1 text-sm text-zinc-500 dark:text-zinc-400" },
            m.csrSubtitle
          )
        ),
        sigBadge(csr)
      ),
      el(
        "div",
        { class: "grid lg:grid-cols-2 gap-4" },
        section(m.commonSubject, subjBody),
        section(m.csrSectionPublicKey, keyBody)
      ),
      section(m.csrSectionRequestedSAN, sanBody),
      el(
        "div",
        { class: "grid lg:grid-cols-2 gap-4" },
        section(m.csrSectionRequestedUsage, usageBody),
        section(m.csrSectionIdentifiers, idBody)
      )
    );
  }

  async function decode() {
    if (busy) return;
    const text = $input.value.trim();
    $error.classList.add("hidden");
    if (!text) {
      $status.textContent = m.inputEmpty;
      return;
    }
    if (text.length > MAX_INPUT_BYTES) {
      showError(m.inputTooLarge);
      return;
    }
    setBusy(true);
    $status.textContent = m.decodingButton;
    try {
      const r = await decodeCSRInput(text);
      if (!r.ok) {
        showError(r.error);
        return;
      }
      $subtitle.textContent = m.decodedSuccess(r.csrs.length);
      const blocks: Node[] = [];
      r.csrs.forEach((csr, i) => {
        if (i > 0)
          blocks.push(
            el("hr", { class: "my-6 border-zinc-100 dark:border-zinc-800" })
          );
        blocks.push(renderCSR(csr));
      });
      mount($body, frag(...blocks));
      $status.textContent = m.decodedSuccess(r.csrs.length);
      if (!$modal.open) $modal.showModal();
    } finally {
      setBusy(false);
    }
  }

  $btn.addEventListener("click", () => void decode());
  document
    .querySelector('[data-action="sample"]')
    ?.addEventListener("click", () => {
      $input.value = SAMPLE_CSR;
      void decode();
    });
  document
    .querySelector('[data-action="clear"]')
    ?.addEventListener("click", () => {
      $input.value = "";
      $error.classList.add("hidden");
      $status.textContent = "";
      $input.focus();
    });
  $input.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "Enter") {
      e.preventDefault();
      void decode();
    }
  });
  $input.addEventListener("paste", () => {
    setTimeout(() => {
      const v = $input.value.trim();
      if (v.includes("-----BEGIN") || (v.length > 80 && /^[A-Za-z0-9+/=\s]+$/.test(v))) {
        void decode();
      }
    }, 0);
  });
</script>
