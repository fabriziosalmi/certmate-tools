---
import Layout from "~/layouts/Layout.astro";
import PrivacyBadge from "~/components/PrivacyBadge.astro";
import Modal from "~/components/Modal.astro";
import ToolNav from "~/components/ToolNav.astro";
import { getMessages, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const m = getMessages(locale);
const desc =
  locale === "it"
    ? "Verifica nel browser quali hostname un certificato copre, secondo RFC 6125: wildcard, IDN, fallback CN. Niente upload."
    : locale === "de"
      ? "Im Browser prüfen, welche Hostnamen ein Zertifikat gemäß RFC 6125 abdeckt — Wildcards, IDN, CN-Fallback. Kein Upload."
      : locale === "fr"
        ? "Vérifiez dans le navigateur quels noms d'hôte un certificat couvre selon RFC 6125 — wildcards, IDN, repli sur CN. Aucun upload."
        : "Check in your browser which hostnames a certificate covers, under RFC 6125 — wildcards, IDN, CN fallback. No upload.";
---

<Layout
  title={m.hostnameValidatorTitle}
  description={desc}
  keywords={[
    "hostname validator",
    "san matcher",
    "rfc 6125",
    "wildcard certificate test",
    "ssl hostname check",
  ]}
  compact
>
  <div
    class="flex-1 flex flex-col items-stretch justify-start md:justify-center px-4 py-6 md:py-10"
  >
    <div class="w-full max-w-3xl mx-auto">
      <ToolNav locale={locale} currentSlug="hostname-validator" />
      <header class="mb-5">
        <h1
          class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50"
        >
          {m.hostnameValidatorTitle}
        </h1>
        <p class="mt-1.5 text-zinc-600 dark:text-zinc-400 leading-relaxed">
          {m.hostnameValidatorTagline}
        </p>
        <div class="mt-3"><PrivacyBadge locale={locale} variant="inline" /></div>
      </header>

      <div
        class:list={[
          "rounded-2xl border shadow-sm overflow-hidden",
          "bg-white border-zinc-200",
          "dark:bg-zinc-900 dark:border-zinc-800",
        ]}
      >
        <div
          class:list={[
            "flex items-center justify-between gap-3 border-b px-4 py-2.5",
            "bg-zinc-50/60 border-zinc-100",
            "dark:bg-zinc-900/80 dark:border-zinc-800",
          ]}
        >
          <div class="text-xs font-medium text-zinc-500 dark:text-zinc-400">Certificate (PEM) + hostnames</div>
          <button
            type="button"
            data-action="clear"
            class="text-xs font-medium text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
            >{m.clear}</button
          >
        </div>
        <textarea
          id="cert-input"
          rows="8"
          spellcheck="false"
          autocomplete="off"
          autocapitalize="off"
          autocorrect="off"
          maxlength="2097152"
          placeholder="-----BEGIN CERTIFICATE-----..."
          class:list={[
            "mono w-full resize-y border-0 px-4 py-3 focus:outline-none focus:ring-0",
            "bg-white text-zinc-900 placeholder:text-zinc-400",
            "dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder:text-zinc-600",
          ]}></textarea>
        <div class="border-t border-zinc-100 dark:border-zinc-800 px-4 py-3">
          <label class="block text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-1.5"
            >Hostnames to test (comma/space/newline separated)</label
          >
          <input
            id="hostname-input"
            type="text"
            spellcheck="false"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            placeholder="example.com www.example.com api.example.com"
            class:list={[
              "mono w-full border rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400/40",
              "border-zinc-200 bg-white text-zinc-900 placeholder:text-zinc-400",
              "dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder:text-zinc-600",
            ]}
          />
        </div>
      </div>

      <div class="mt-4 flex items-center gap-3 flex-wrap">
        <button
          type="button"
          data-action="check"
          class:list={[
            "inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
            "bg-zinc-900 text-white hover:bg-zinc-800",
            "dark:bg-brand-500 dark:text-zinc-50 dark:hover:bg-brand-400",
          ]}>Check coverage</button
        >
        <p id="status" role="status" aria-live="polite" class="text-sm text-zinc-500 dark:text-zinc-400"></p>
      </div>

      <div
        id="error"
        role="alert"
        class:list={[
          "mt-5 hidden rounded-lg border px-4 py-3 text-sm",
          "bg-red-50 border-red-200 text-red-900",
          "dark:bg-red-950/40 dark:border-red-900/60 dark:text-red-200",
        ]}
      >
      </div>

    </div>
  </div>

  <Modal id="result-modal" locale={locale}>
    <span slot="title">{m.hostnameValidatorTitle}</span>
    <span slot="subtitle" id="result-modal-subtitle"></span>
    <div id="result-body"></div>
  </Modal>
</Layout>

<script>
  import { validateHostname, type HostnameMatchResult } from "~/lib/hostname-validator";
  import { escapeHtml } from "~/lib/util";

  const $cert = document.getElementById("cert-input") as HTMLTextAreaElement;
  const $host = document.getElementById("hostname-input") as HTMLInputElement;
  const $status = document.getElementById("status") as HTMLElement;
  const $error = document.getElementById("error") as HTMLElement;
  const $modal = document.getElementById("result-modal") as HTMLDialogElement;
  const $subtitle = document.getElementById("result-modal-subtitle") as HTMLElement;
  const $body = document.getElementById("result-body") as HTMLElement;
  const $btn = document.querySelector('[data-action="check"]') as HTMLButtonElement;

  let busy = false;
  function setBusy(v: boolean) {
    busy = v;
    $btn.disabled = v;
    $btn.textContent = v ? "Working…" : "Check coverage";
  }
  function showError(msg: string) {
    $error.textContent = msg;
    $error.classList.remove("hidden");
    $status.textContent = "";
  }

  function renderResult(r: HostnameMatchResult): string {
    const badge = r.matched
      ? `<span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 text-emerald-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-emerald-200 dark:bg-emerald-950/40 dark:text-emerald-200 dark:ring-emerald-900/60"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>covered</span>`
      : `<span class="inline-flex items-center gap-1.5 rounded-full bg-red-100 text-red-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-red-200 dark:bg-red-950/50 dark:text-red-200 dark:ring-red-900/60"><span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>not covered</span>`;
    const rules = r.rules
      .map(
        (rl) =>
          `<li class="flex items-start gap-2"><span class="${rl.ok ? "text-emerald-600 dark:text-emerald-400" : "text-red-600 dark:text-red-400"} mt-0.5">${rl.ok ? "✓" : "✗"}</span><span><span class="font-medium">${escapeHtml(rl.rule)}</span> — <span class="text-zinc-600 dark:text-zinc-400">${escapeHtml(rl.detail)}</span></span></li>`
      )
      .join("");
    const matchLine = r.matchedEntry
      ? `<p class="text-sm text-zinc-600 dark:text-zinc-400 mt-1">matched by <code class="mono bg-zinc-100 dark:bg-zinc-800 px-1.5 rounded">${escapeHtml(r.matchedEntry.type)}: ${escapeHtml(r.matchedEntry.value)}</code></p>`
      : "";
    const notes = r.notes.length
      ? `<ul class="mt-3 text-xs text-amber-800 dark:text-amber-300 space-y-1 list-disc pl-5">${r.notes.map((n) => `<li>${escapeHtml(n)}</li>`).join("")}</ul>`
      : "";
    return `<article class="rounded-lg border border-zinc-200 bg-white p-5 dark:bg-zinc-900/40 dark:border-zinc-800">
      <header class="flex items-start justify-between gap-3 flex-wrap">
        <div>
          <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-50 break-all">${escapeHtml(r.hostname)}</h3>
          ${matchLine}
        </div>
        ${badge}
      </header>
      <ul class="mt-3 space-y-1.5 text-sm text-zinc-700 dark:text-zinc-300">${rules}</ul>
      ${notes}
    </article>`;
  }

  async function check() {
    if (busy) return;
    $error.classList.add("hidden");
    if (!$cert.value.trim()) {
      $status.textContent = "Paste a certificate first.";
      return;
    }
    if (!$host.value.trim()) {
      $status.textContent = "Enter at least one hostname.";
      return;
    }
    setBusy(true);
    $status.textContent = "Working…";
    try {
      const r = await validateHostname({ pem: $cert.value, hostname: $host.value });
      if (!r.ok) {
        showError(r.error);
        return;
      }
      const ok = r.results.filter((x) => x.matched).length;
      $subtitle.textContent = `${ok}/${r.results.length} hostnames covered.`;
      $body.innerHTML = r.results.map(renderResult).join('<div class="my-3"></div>');
      $status.textContent = $subtitle.textContent;
      if (!$modal.open) $modal.showModal();
    } finally {
      setBusy(false);
    }
  }

  $btn.addEventListener("click", () => void check());
  document
    .querySelector('[data-action="clear"]')
    ?.addEventListener("click", () => {
      $cert.value = "";
      $host.value = "";
      $error.classList.add("hidden");
      $status.textContent = "";
      $cert.focus();
    });
  $host.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      void check();
    }
  });
</script>
