---
import Layout from "~/layouts/Layout.astro";
import ToolCard from "~/components/ToolCard.astro";
import { internalTools, externalTools, type Category } from "~/data/tools";
import { getMessages, localizedPath, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const m = getMessages(locale);

const catLabels: Record<Category, { label: string; blurb: string }> = {
  decode: { label: m.catDecodeLabel, blurb: m.catDecodeBlurb },
  validate: { label: m.catValidateLabel, blurb: m.catValidateBlurb },
  inspect: { label: m.catInspectLabel, blurb: m.catInspectBlurb },
  monitor: { label: m.catMonitorLabel, blurb: m.catMonitorBlurb },
  acme: { label: m.catAcmeLabel, blurb: m.catAcmeBlurb },
  compliance: { label: m.catComplianceLabel, blurb: m.catComplianceBlurb },
};

const liveCount = internalTools.filter((t) => t.status === "live").length;
const internalCategoryOrder: Category[] = [
  "decode",
  "validate",
  "inspect",
  "acme",
  "compliance",
];
const externalCategoryOrder: Category[] = [
  "decode",
  "validate",
  "inspect",
  "monitor",
  "acme",
  "compliance",
];

const groupedInternal = internalCategoryOrder
  .map((cat) => ({
    cat,
    tools: internalTools.filter((t) => t.category === cat),
  }))
  .filter((g) => g.tools.length > 0);

const groupedExternal = externalCategoryOrder
  .map((cat) => ({
    cat,
    tools: externalTools.filter((t) => t.category === cat),
  }))
  .filter((g) => g.tools.length > 0);

const seoDescription =
  locale === "en"
    ? "Free, privacy-first online tools for TLS certificates, CSRs, ACME, DNS and EU compliance. Everything runs in your browser — no uploads, no tracking."
    : locale === "it"
      ? "Strumenti online gratuiti e privacy-first per certificati TLS, CSR, ACME, DNS e compliance EU. Tutto nel tuo browser — niente upload, niente tracking."
      : locale === "de"
        ? "Kostenlose, datenschutzfreundliche Online-Tools für TLS-Zertifikate, CSRs, ACME, DNS und EU-Compliance. Alles im Browser — kein Upload, kein Tracking."
        : "Outils gratuits et respectueux de la vie privée pour certificats TLS, CSR, ACME, DNS et conformité UE. Tout dans le navigateur — aucun upload, aucun tracker.";
---

<Layout
  title="CertMate Tools"
  description={seoDescription}
  keywords={[
    "ssl tools",
    "certificate decoder",
    "csr decoder",
    "ssl checker",
    "tls tools",
    "acme tools",
    "nis2 tls",
    "decoder certificati",
    "tools certificati ssl",
  ]}
>
  <section
    class:list={[
      "border-b",
      "border-zinc-100 bg-gradient-to-b from-brand-50/60 to-white",
      "dark:border-zinc-800 dark:from-brand-900/20 dark:to-zinc-950",
    ]}
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-5 py-12 md:py-24">
      <div class="max-w-3xl">
        <span
          class:list={[
            "inline-flex items-center gap-1.5 rounded-full ring-1 px-3 py-1 text-xs font-medium",
            "bg-white ring-zinc-200 text-zinc-700",
            "dark:bg-zinc-900 dark:ring-zinc-800 dark:text-zinc-300",
          ]}
        >
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          {m.homeBadge(liveCount)}
        </span>
        <h1
          class="mt-5 text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] md:leading-[1.05] text-zinc-900 dark:text-zinc-50"
        >
          {m.homeHeadlineL1}
          <br class="hidden md:block" />
          {m.homeHeadlineL2a}
          <span class="text-brand-700 dark:text-brand-400">{m.homeHeadlineL2b}</span>.
        </h1>
        <p class="mt-5 text-base sm:text-lg leading-relaxed max-w-2xl text-zinc-600 dark:text-zinc-300">
          {m.homeIntro}
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="#tools"
            class:list={[
              "inline-flex items-center gap-2 rounded-md px-4 py-2.5 text-sm font-medium transition-colors",
              "bg-zinc-900 text-white hover:bg-zinc-800",
              "dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-white",
            ]}
          >
            {m.homeCtaBrowse}
          </a>
          <a
            href={localizedPath(locale, "/certificate-decoder/")}
            class:list={[
              "inline-flex items-center gap-2 rounded-md px-4 py-2.5 text-sm font-medium ring-1 transition-colors",
              "bg-white text-zinc-900 ring-zinc-300 hover:bg-zinc-50",
              "dark:bg-zinc-900 dark:text-zinc-100 dark:ring-zinc-700 dark:hover:bg-zinc-800",
            ]}
          >
            {m.homeCtaTry}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="tools" class="mx-auto max-w-6xl px-4 sm:px-5 py-14 sm:py-16">
    <div class="flex items-baseline justify-between flex-wrap gap-3 mb-2">
      <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">
        {m.homeOurTools}
      </h2>
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        {m.homeOurToolsClaim}
      </p>
    </div>
    <p class="text-zinc-600 max-w-2xl mb-10 dark:text-zinc-400">
      {m.homeOurToolsLead}
    </p>

    <div class="space-y-12">
      {
        groupedInternal.map(({ cat, tools }) => (
          <div>
            <div class="mb-4 flex flex-col sm:flex-row sm:items-baseline gap-1.5 sm:gap-3">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-700 dark:text-brand-400">
                {catLabels[cat].label}
              </h3>
              <p class="text-sm text-zinc-500 dark:text-zinc-400">
                {catLabels[cat].blurb}
              </p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {tools.map((t) => (
                <ToolCard tool={t} locale={locale} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section
    class:list={[
      "border-t",
      "border-zinc-100 bg-zinc-50/60",
      "dark:border-zinc-800 dark:bg-zinc-950/60",
    ]}
  >
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="flex items-baseline justify-between flex-wrap gap-3 mb-2">
        <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">
          {m.homeExternal}
        </h2>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">
          {m.homeExternalCurated}
        </p>
      </div>
      <p class="text-zinc-600 max-w-2xl mb-10 dark:text-zinc-400">
        {m.homeExternalLead}
      </p>

      <div class="space-y-12">
        {
          groupedExternal.map(({ cat, tools }) => (
            <div>
              <div class="mb-4">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-700 dark:text-zinc-300">
                  {catLabels[cat].label}
                </h3>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {tools.map((t) => (
                  <ToolCard tool={t} locale={locale} />
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-5 py-16 sm:py-20">
    <div
      class:list={[
        "rounded-2xl p-6 sm:p-10 md:p-14 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 text-white",
        "bg-zinc-900",
        "dark:bg-gradient-to-br dark:from-zinc-900 dark:to-zinc-800",
      ]}
    >
      <div class="max-w-xl">
        <h3 class="text-2xl font-bold tracking-tight">
          {m.homeBottomTitle}
        </h3>
        <p class="mt-3 text-zinc-300 leading-relaxed">
          {m.homeBottomBody}
          {" "}
          <a
            href="https://cabforum.org/2025/04/11/ballot-sc081v3-introduce-schedule-of-reducing-validity-and-data-reuse-periods/"
            target="_blank"
            rel="noopener"
            class="underline decoration-zinc-500 hover:decoration-white"
            >SC-081v3 ↗</a
          >
        </p>
      </div>
      <a
        href="https://github.com/fabriziosalmi/certmate"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-md bg-white text-zinc-900 px-5 py-3 font-medium hover:bg-zinc-100 transition-colors shrink-0"
      >
        {m.homeBottomCta}
      </a>
    </div>
  </section>
</Layout>
