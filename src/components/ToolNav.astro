---
import { internalTools } from "~/data/tools";
import {
  getMessages,
  localizedPath,
  toolLabels,
  type Locale,
} from "~/i18n";

interface Props {
  locale: Locale;
  currentSlug: string;
}

const { locale, currentSlug } = Astro.props;
const m = getMessages(locale);
const liveTools = internalTools.filter((t) => t.status === "live");
---

<nav
  aria-label="Tool navigation"
  class:list={[
    "-mx-4 px-4 sm:mx-0 sm:px-0 mb-5 overflow-x-auto",
    "[scrollbar-width:none] [&::-webkit-scrollbar]:hidden",
  ]}
>
  <ul class="flex items-center gap-2 whitespace-nowrap pb-1">
    <li class="shrink-0">
      <a
        href={localizedPath(locale, "/")}
        class:list={[
          "inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 text-xs sm:text-sm font-medium transition-colors",
          "text-zinc-500 hover:text-zinc-900 hover:bg-zinc-100",
          "dark:text-zinc-400 dark:hover:text-zinc-100 dark:hover:bg-zinc-800",
        ]}
        title={m.navAllTools}
      >
        <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 fill-current" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M3 4a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 8a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H4a1 1 0 01-1-1v-4zm8-8a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V4zm0 8a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"
            clip-rule="evenodd"></path>
        </svg>
        <span class="hidden sm:inline">{m.navAllTools}</span>
      </a>
    </li>
    <li
      class="shrink-0 mx-1 text-zinc-300 dark:text-zinc-700 select-none"
      aria-hidden="true"
    >
      /
    </li>
    {
      liveTools.map((t) => {
        const isActive = t.slug === currentSlug;
        return (
          <li class="shrink-0">
            <a
              href={localizedPath(locale, `/${t.slug}/`)}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "inline-flex items-center rounded-md px-2.5 py-1.5 text-xs sm:text-sm font-medium transition-colors",
                isActive
                  ? "bg-brand-100 text-brand-800 ring-1 ring-brand-200 dark:bg-brand-900/40 dark:text-brand-100 dark:ring-brand-700/50"
                  : "text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:text-zinc-100 dark:hover:bg-zinc-800",
              ]}
            >
              {toolLabels(m, t.slug).title}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
