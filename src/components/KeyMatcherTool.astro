---
import Layout from "~/layouts/Layout.astro";
import PrivacyBadge from "~/components/PrivacyBadge.astro";
import Modal from "~/components/Modal.astro";
import ToolNav from "~/components/ToolNav.astro";
import { getMessages, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const m = getMessages(locale);
const desc =
  locale === "it"
    ? "Verifica nel browser che una chiave privata corrisponda a un certificato. Niente upload — Web Crypto + confronto SPKI."
    : locale === "de"
      ? "Im Browser prüfen, ob ein privater Schlüssel zum Zertifikat passt. Kein Upload — Web Crypto + SPKI-Vergleich."
      : locale === "fr"
        ? "Vérifiez dans le navigateur qu'une clé privée correspond à un certificat. Aucun upload — Web Crypto + comparaison SPKI."
        : "Confirm a private key matches a certificate, fully in your browser. Web Crypto only — SPKI fingerprint comparison.";
---

<Layout
  title={m.keyMatcherTitle}
  description={desc}
  keywords={[
    "certificate key matcher",
    "private key match",
    "ssl key check",
    "match chiave certificato",
    "spki match",
  ]}
  compact
>
  <div
    class="flex-1 flex flex-col items-stretch justify-start md:justify-center px-4 py-6 md:py-10"
  >
    <div class="w-full max-w-3xl mx-auto">
      <ToolNav locale={locale} currentSlug="key-matcher" />
      <header class="mb-5">
        <h1
          class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50"
        >
          {m.keyMatcherTitle}
        </h1>
        <p class="mt-1.5 text-zinc-600 dark:text-zinc-400 leading-relaxed">
          {m.keyMatcherTagline}
        </p>
        <div class="mt-3"><PrivacyBadge locale={locale} variant="block" /></div>
      </header>

      <div class="grid md:grid-cols-2 gap-4">
        <div
          class:list={[
            "rounded-2xl border shadow-sm overflow-hidden",
            "bg-white border-zinc-200",
            "dark:bg-zinc-900 dark:border-zinc-800",
          ]}
        >
          <div
            class:list={[
              "border-b px-4 py-2.5 text-xs font-medium",
              "bg-zinc-50/60 border-zinc-100 text-zinc-500",
              "dark:bg-zinc-900/80 dark:border-zinc-800 dark:text-zinc-400",
            ]}
          >
            Certificate (PEM)
          </div>
          <textarea
            id="cert-input"
            rows="10"
            spellcheck="false"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            placeholder="-----BEGIN CERTIFICATE-----..."
            class:list={[
              "mono w-full resize-y border-0 px-4 py-3 text-base sm:text-sm leading-relaxed min-h-44 focus:outline-none focus:ring-0",
              "bg-white text-zinc-900 placeholder:text-zinc-400",
              "dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder:text-zinc-600",
            ]}></textarea>
        </div>
        <div
          class:list={[
            "rounded-2xl border shadow-sm overflow-hidden",
            "bg-white border-zinc-200",
            "dark:bg-zinc-900 dark:border-zinc-800",
          ]}
        >
          <div
            class:list={[
              "border-b px-4 py-2.5 text-xs font-medium",
              "bg-zinc-50/60 border-zinc-100 text-zinc-500",
              "dark:bg-zinc-900/80 dark:border-zinc-800 dark:text-zinc-400",
            ]}
          >
            Private key (PKCS#8 PEM)
          </div>
          <textarea
            id="key-input"
            rows="10"
            spellcheck="false"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            placeholder="-----BEGIN PRIVATE KEY-----..."
            class:list={[
              "mono w-full resize-y border-0 px-4 py-3 text-base sm:text-sm leading-relaxed min-h-44 focus:outline-none focus:ring-0",
              "bg-white text-zinc-900 placeholder:text-zinc-400",
              "dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder:text-zinc-600",
            ]}></textarea>
        </div>
      </div>

      <div class="mt-4 flex items-center gap-3 flex-wrap">
        <button
          type="button"
          data-action="match"
          class:list={[
            "inline-flex w-full sm:w-auto justify-center items-center gap-2 rounded-md px-5 py-3 text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
            "bg-zinc-900 text-white hover:bg-zinc-800",
            "dark:bg-brand-500 dark:text-zinc-50 dark:hover:bg-brand-400",
          ]}>Match</button
        >
        <button
          type="button"
          data-action="clear"
          class="text-xs font-medium text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
          >{m.clear}</button
        >
        <p id="status" role="status" aria-live="polite" class="w-full sm:w-auto text-xs sm:text-sm leading-relaxed text-zinc-500 dark:text-zinc-400"></p>
      </div>

      <div
        id="error"
        role="alert"
        class:list={[
          "mt-5 hidden rounded-lg border px-4 py-3 text-sm",
          "bg-red-50 border-red-200 text-red-900",
          "dark:bg-red-950/40 dark:border-red-900/60 dark:text-red-200",
        ]}
      >
      </div>

    </div>
  </div>

  <Modal id="result-modal" locale={locale}>
    <span slot="title">{m.keyMatcherTitle}</span>
    <span slot="subtitle" id="result-modal-subtitle"></span>
    <div id="result-body"></div>
  </Modal>
</Layout>

<script>
  import { matchKeyAndCert } from "~/lib/key-match";
  import { escapeHtml, MAX_INPUT_BYTES } from "~/lib/util";

  const $cert = document.getElementById("cert-input") as HTMLTextAreaElement;
  const $key = document.getElementById("key-input") as HTMLTextAreaElement;
  const $status = document.getElementById("status") as HTMLElement;
  const $error = document.getElementById("error") as HTMLElement;
  const $modal = document.getElementById("result-modal") as HTMLDialogElement;
  const $subtitle = document.getElementById("result-modal-subtitle") as HTMLElement;
  const $body = document.getElementById("result-body") as HTMLElement;
  const $btn = document.querySelector('[data-action="match"]') as HTMLButtonElement;

  let busy = false;
  function setBusy(v: boolean) {
    busy = v;
    $btn.disabled = v;
    $btn.textContent = v ? "Working…" : "Match";
  }
  function showError(msg: string) {
    $error.textContent = msg;
    $error.classList.remove("hidden");
    $status.textContent = "";
  }

  async function run() {
    if (busy) return;
    $error.classList.add("hidden");
    if (!$cert.value.trim() || !$key.value.trim()) {
      $status.textContent = "Paste both a certificate and a private key.";
      return;
    }
    if ($cert.value.length > MAX_INPUT_BYTES || $key.value.length > MAX_INPUT_BYTES) {
      showError("Input is too large.");
      return;
    }
    setBusy(true);
    $status.textContent = "Working…";
    try {
      const r = await matchKeyAndCert($cert.value, $key.value);
      if (!r.ok) {
        showError(r.error);
        return;
      }
      const res = r.result;
      const badge = res.match
        ? `<span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 text-emerald-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-emerald-200 dark:bg-emerald-950/40 dark:text-emerald-200 dark:ring-emerald-900/60"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>match</span>`
        : `<span class="inline-flex items-center gap-1.5 rounded-full bg-red-100 text-red-800 px-2.5 py-1 text-xs font-semibold ring-1 ring-red-200 dark:bg-red-950/50 dark:text-red-200 dark:ring-red-900/60"><span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>no match</span>`;
      const fields = [
        ["Subject", res.certSubject],
        ["Common name", res.certCommonName ?? "—"],
        ["Key algorithm", res.keyAlgorithm],
      ];
      if (res.keyKeySize) fields.push(["Key size", `${res.keyKeySize} bits`]);
      if (res.keyNamedCurve) fields.push(["Named curve", res.keyNamedCurve]);
      const fieldHtml = fields
        .map(
          ([k, v]) =>
            `<div><dt class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">${escapeHtml(k!)}</dt><dd class="mt-1 text-sm text-zinc-900 dark:text-zinc-100 break-all mono">${escapeHtml(v!)}</dd></div>`
        )
        .join("");
      $subtitle.textContent = res.match
        ? "Private key matches the certificate."
        : "Private key does NOT match the certificate.";
      $body.innerHTML = `<article class="space-y-4">
        <header class="flex items-start justify-between gap-3 flex-wrap">
          <div>
            <h2 class="text-lg font-bold tracking-tight text-zinc-900 dark:text-zinc-50">${escapeHtml(res.certCommonName ?? res.certSubject)}</h2>
            <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">${escapeHtml(res.reason)}</p>
          </div>
          ${badge}
        </header>
        <div class="grid sm:grid-cols-2 gap-4 rounded-lg border border-zinc-200 bg-white p-5 dark:bg-zinc-900/40 dark:border-zinc-800">${fieldHtml}</div>
        <div class="rounded-lg border border-zinc-200 bg-white p-5 dark:bg-zinc-900/40 dark:border-zinc-800 space-y-3 text-sm">
          <div><dt class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Cert SPKI SHA-256</dt><dd class="mono mt-1 break-all">${escapeHtml(res.certSpkiSha256)}</dd></div>
          <div><dt class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Derived SPKI SHA-256</dt><dd class="mono mt-1 break-all">${escapeHtml(res.derivedSpkiSha256)}</dd></div>
        </div>
      </article>`;
      $status.textContent = $subtitle.textContent;
      if (!$modal.open) $modal.showModal();
    } finally {
      setBusy(false);
    }
  }

  $btn.addEventListener("click", () => void run());
  document
    .querySelector('[data-action="clear"]')
    ?.addEventListener("click", () => {
      $cert.value = "";
      $key.value = "";
      $error.classList.add("hidden");
      $status.textContent = "";
      $cert.focus();
    });
</script>
